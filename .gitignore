# Root safety net — nested engine/.gitignore also applies.

# secrets / env
.env
.env.*
!.env.example
config.env
*.key

# data / indexes — NEVER commit (embeddings of your entire vault)
index.db
index.db-*
*.sqlite
*.sqlite-*

# python
.venv/
__pycache__/
*.pyc

# php / node
vendor/
node_modules/

# os / logs
.DS_Store
*.log

# sqlite indexes (any name)
*.db
*.db-*
engine/src/apo_engine.egg-info/
