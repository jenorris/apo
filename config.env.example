# Apo — local profile (example)

# Copy to `.env` or merge into `config.env`, then edit paths.

APO_NOTES_ROOT="${APO_NOTES_ROOT:-$HOME/Notes/MyVault}"
APO_INDEX="${APO_INDEX:-$HOME/Code/apo/engine/index.db}"
# Desk default: Ollama bge-m3. Optional ONNX: fastembed + BAAI/bge-large-en-v1.5 (full reindex).
APO_EMBED_BACKEND="${APO_EMBED_BACKEND:-ollama}"
APO_MODEL="${APO_MODEL:-bge-m3}"
APO_OLLAMA_URL="${APO_OLLAMA_URL:-http://127.0.0.1:11434}"
OLLAMA_KEEP_ALIVE="${OLLAMA_KEEP_ALIVE:-5m}"
APO_COLLECTION="${APO_COLLECTION:-notes_global}"
APO_INGEST_DIR="${APO_INGEST_DIR:-resources/wiki}"

# Watcher
APO_ENGINE_BIN="${APO_ENGINE_BIN:-$HOME/Code/apo/engine/.venv/bin/apo-engine}"
WATCH_INTERVAL="${WATCH_INTERVAL:-30}"
WATCH_RECONCILE_INTERVAL="${WATCH_RECONCILE_INTERVAL:-300}"
WATCH_PID_DIR="${WATCH_PID_DIR:-$HOME/.apo}"
